        const parts = rIncons.split(',').map(s => s.trim());
        parts.forEach(p => inconsistency[p] = (inconsistency[p] || 0) + 1);
      }
    });

    // Sort by count descending
    const sortObj = (obj) => Object.entries(obj).sort((a, b) => b[1] - a[1]).map(e => ({ name: e[0], count: e[1] }));

    return {
      inaccuracy: sortObj(inaccuracy),
      inconsistency: sortObj(inconsistency)
    };
