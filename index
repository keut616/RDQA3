      'monthly report deadline submission', 'completeness source document', 'source document availavility',
      'source document standard', 'accuracy_dhis2', 'consistency', 'system_assesment'
    ];
    
    const sums = {};
    const counts = {};
    keys.forEach(k => { sums[k] = 0; counts[k] = 0; });

    filteredAllData.forEach(row => {
      keys.forEach(key => {
        let val = parseFloat(row[key]);
        if (!isNaN(val)) {
          sums[key] += val;
          counts[key] += 1;
        }
      });
    });

    const result = [];
    keys.forEach(key => {
      const avg = counts[key] > 0 ? (sums[key] / counts[key]).toFixed(1) : 0;
      // Make label beautiful
      const label = key.split('_').join(' ').replace(/\b\w/g, l => l.toUpperCase());
      result.push({ key, label, value: parseFloat(avg) });
    });

    return result;
  }, [filteredAllData]);

  // Section 3: Causes Aggregation
  const causesData = useMemo(() => {
    const inaccuracy = {};
    const inconsistency = {};

    filteredAllData.forEach(row => {
