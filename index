      const rIncons = row['reason of inconsistency'];

      if (rInacc && rInacc !== 'No discrepancy - ບໍ່ມີຄ່າຜິດດ່ຽງ' && rInacc.trim() !== '') {
        const parts = rInacc.split(',').map(s => s.trim());
        parts.forEach(p => inaccuracy[p] = (inaccuracy[p] || 0) + 1);
