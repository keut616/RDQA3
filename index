  // AI Chat State
  const [qaInput, setQaInput] = useState('');
  const [chatHistory, setChatHistory] = useState([]);
  const [isAiThinking, setIsAiThinking] = useState(false);

  // Filters State
  const [filters, setFilters] = useState({
    province: [],
    district: [],
    healthCenter: [],
    roundNo: [],
    monthYear: []
  });

  // Handle File Uploads
  const handleFileUpload = (e, type) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (evt) => {
      const text = evt.target.result;
      const parsed = parseCSV(text);
      if (type === 'all') setAllData(parsed);
      if (type === 'kap') setKapData(parsed);
    };
    reader.readAsText(file);
  };

  // --- Filtering Logic (Cascading) ---
  const filteredAllData = useMemo(() => {
    return allData.filter(row => {
      // Month Year is derived from Date of visit
      const rowMonthYear = getMonthYear(row['Date of visit']);

      return (
        (filters.province.length === 0 || filters.province.includes(row.province)) &&
        (filters.district.length === 0 || filters.district.includes(row.district)) &&
        (filters.healthCenter.length === 0 || filters.healthCenter.includes(row['health center'])) &&
        (filters.roundNo.length === 0 || filters.roundNo.includes(row['Round no'])) &&
        (filters.monthYear.length === 0 || filters.monthYear.includes(rowMonthYear))
      );
    });
  }, [allData, filters]);

  // Dynamically generate options based on CURRENT filter state (Cascading)
  const filterOptions = useMemo(() => {
    const options = { province: new Set(), district: new Set(), healthCenter: new Set(), roundNo: new Set(), monthYear: new Set() };
    
    // To make it truly cascading, we look at the data before applying the *current field's* filter
    allData.forEach(row => {
      // Logic to extract MM-YYYY
      const rowMonthYear = getMonthYear(row['Date of visit']);

      const matchProv = filters.province.length === 0 || filters.province.includes(row.province);
      const matchDist = filters.district.length === 0 || filters.district.includes(row.district);
      const matchHC = filters.healthCenter.length === 0 || filters.healthCenter.includes(row['health center']);
      const matchRound = filters.roundNo.length === 0 || filters.roundNo.includes(row['Round no']);
      const matchMY = filters.monthYear.length === 0 || filters.monthYear.includes(rowMonthYear);

      // Populate options if it matches OTHER filters
      if (matchDist && matchHC && matchRound && matchMY) if(row.province) options.province.add(row.province);
      if (matchProv && matchHC && matchRound && matchMY) if(row.district) options.district.add(row.district);
      if (matchProv && matchDist && matchRound && matchMY) if(row['health center']) options.healthCenter.add(row['health center']);
      if (matchProv && matchDist && matchHC && matchMY) if(row['Round no']) options.roundNo.add(row['Round no']);
      if (matchProv && matchDist && matchHC && matchRound) if(rowMonthYear) options.monthYear.add(rowMonthYear);
    });

    return {
      province: Array.from(options.province).sort(),
      district: Array.from(options.district).sort(),
      healthCenter: Array.from(options.healthCenter).sort(),
      roundNo: Array.from(options.roundNo).sort(),
      monthYear: Array.from(options.monthYear).sort()
    };
  }, [allData, filters]);


  // --- Calculations for Sections ---

  // Section 1: KPIs
  const kpiData = useMemo(() => {
    const distSet = new Set();
    const hcSet = new Set();
    const indSet = new Set();

    // ນໍາໃຊ້ຂໍ້ມູນທີ່ຖືກກັ່ນຕອງແລ້ວ (filteredAllData) ມາຄິດໄລ່ ເພື່ອໃຫ້ເຊື່ອມໂຍງກັບທຸກໆແທັບແບບ 100%
